{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES6",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    
    // Куда складывать скомпилированные .js файлы
    "outDir": "./dist/js",
    
    // Откуда брать TypeScript файлы
    "rootDir": "./src/js",
    
    // Безопасность 
    "strict": true,            // Включаем все строгие проверки
    "noImplicitAny": true,     // Запрещаем неявный any
    "strictNullChecks": true,    // Проверяем null/undefined
    "strictFunctionTypes": true,   // Строгая проверка функций
    "strictBindCallApply": true,   // Строгая проверка bind/call/apply
    "strictPropertyInitialization": true, // Строгая инициализация свойств
    "noImplicitThis": true,                // Запрещаем неявный this
    "alwaysStrict": true,                  // Всегда "use strict"
    "skipLibCheck": true,       // Пропускаем проверку библиотек

    // Дополнительные проверки
    "noUnusedLocals": true,               // Предупреждать о неиспользуемых переменных
    "noUnusedParameters": true,            // Предупреждать о неиспользуемых параметрах
    "noImplicitReturns": true,             // Проверять что все пути возвращают значение
    "noFallthroughCasesInSwitch": true,    // Проверять switch на проваливания
    
    // Разрешить .js файлы (чтобы мигрировать постепенно)
    "allowJs": false,                      // Меняем на false - весь проект теперь в TS
    "checkJs": false,                       // Проверку JS тоже отключаем
    
    // Настройки модулей
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    
    // Для отладки
    "sourceMap": true,
    
    // Чтобы TypeScript не жаловался на импорты
    "baseUrl": "./src/js",        // Базовый путь для импортов
    "paths": {
      "@/*": ["./*"]              // Можно использовать @/components/header
    }
  },
  
  // Какие файлы компилировать
  "include": [
    "src/js/**/*.ts",      // Только TS файлы (JS больше не включаем)
    "src/js/**/*.d.ts"     // Файлы с описанием типов
  ],
  
  // Что игнорировать
  "exclude": [
    "node_modules",
    "dist",
    "src/scss",           // Стили не проверяем
    "src/assets"          // Картинки/шрифты не проверяем
  ]
}