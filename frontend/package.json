{
  "name": "online-store-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "browser-sync start --server --files '**/*.html, **/*.js, **/*.css'",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "compile": "tsc",
    "compile:watch": "tsc --watch"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "browser-sync": "^3.0.4"
  }
}